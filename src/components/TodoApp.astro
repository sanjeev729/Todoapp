---
// src/components/TodoApp.astro
---

<div class="relative w-full max-w-2xl mx-auto z-10">
  <!-- Todo Controller Input Card -->
  <div class="bg-canvas border border-hairline rounded-lg p-6 shadow-lvl-3 transition-shadow duration-300 hover:shadow-lvl-4">
    <form id="todo-form" class="flex gap-3 items-center">
      <div class="relative flex-1">
        <input 
          type="text" 
          id="todo-input" 
          placeholder="What needs to be done?" 
          class="w-full h-11 px-4 py-2 bg-canvas text-ink border border-hairline rounded-[6px] text-sm placeholder-mute focus:outline-none focus:border-hairline-strong focus:ring-1 focus:ring-hairline-strong transition-all font-sans"
          autocomplete="off"
          required
        />
      </div>
      <button 
        type="submit" 
        class="h-11 px-6 bg-primary text-on-primary hover:bg-black/90 text-sm font-medium rounded-[6px] shadow-lvl-1 hover:shadow-lvl-2 transition-all cursor-pointer flex items-center gap-2 whitespace-nowrap"
      >
        <span>Add task</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
      </button>
    </form>

    <!-- Filters & Stats Row -->
    <div class="flex flex-col sm:flex-row gap-4 items-center justify-between mt-6 pt-4 border-t border-hairline text-xs font-mono text-body">
      <!-- Remaining Counts -->
      <div id="todo-stats-count" class="flex items-center gap-1">
        <span class="font-medium text-ink" id="active-count">0</span>
        <span>items left</span>
      </div>

      <!-- Filter Buttons (tab-ghost style) -->
      <div class="flex gap-1 bg-canvas-soft-2 p-1 rounded-full border border-hairline">
        <button 
          type="button" 
          data-filter="all" 
          class="filter-btn px-3 py-1 rounded-full text-xs font-medium cursor-pointer transition-all bg-canvas text-ink shadow-lvl-1"
        >
          All
        </button>
        <button 
          type="button" 
          data-filter="active" 
          class="filter-btn px-3 py-1 rounded-full text-xs font-medium cursor-pointer transition-all hover:text-ink"
        >
          Active
        </button>
        <button 
          type="button" 
          data-filter="completed" 
          class="filter-btn px-3 py-1 rounded-full text-xs font-medium cursor-pointer transition-all hover:text-ink"
        >
          Completed
        </button>
      </div>

      <!-- Actions -->
      <button 
        type="button" 
        id="clear-completed-btn" 
        class="hover:text-error text-xs font-medium cursor-pointer transition-colors"
      >
        Clear completed
      </button>
    </div>
  </div>

  <!-- Todo List Container -->
  <div class="mt-6">
    <div id="todo-list" class="space-y-3">
      <!-- Dynamic list loaded via client script -->
    </div>

    <!-- Empty State Card (ex-empty-state-card) -->
    <div id="empty-state" class="hidden flex flex-col items-center justify-center py-16 px-6 bg-canvas-soft border border-hairline border-dashed rounded-lg text-center shadow-inner mt-4">
      <div class="w-12 h-12 rounded-full bg-canvas border border-hairline flex items-center justify-center text-mute shadow-lvl-1 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-body"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
      </div>
      <h3 class="text-sm font-semibold text-ink mb-1">No tasks today.</h3>
      <p class="text-xs text-mute max-w-xs leading-relaxed">
        Your workspace is clean. Create a new task above to begin organizing your workflow.
      </p>
    </div>
  </div>
</div>

<!-- Toast Notifications Container -->
<div id="toast-container" class="fixed bottom-6 right-6 z-50 flex flex-col gap-2 pointer-events-none max-w-sm w-full">
  <!-- Dynamic toasts populate here -->
</div>

<script>
  interface Todo {
    id: string;
    text: string;
    completed: boolean;
  }

  // State
  let todos: Todo[] = [];
  let currentFilter: 'all' | 'active' | 'completed' = 'all';

  // Elements
  const todoForm = document.getElementById('todo-form') as HTMLFormElement;
  const todoInput = document.getElementById('todo-input') as HTMLInputElement;
  const todoList = document.getElementById('todo-list') as HTMLDivElement;
  const emptyState = document.getElementById('empty-state') as HTMLDivElement;
  const activeCountEl = document.getElementById('active-count') as HTMLSpanElement;
  const clearCompletedBtn = document.getElementById('clear-completed-btn') as HTMLButtonElement;
  const filterBtns = document.querySelectorAll('.filter-btn');
  const toastContainer = document.getElementById('toast-container') as HTMLDivElement;

  // Load Todos from LocalStorage
  function loadTodos() {
    try {
      const stored = localStorage.getItem('taskflow_todos');
      if (stored) {
        todos = JSON.parse(stored);
      } else {
        // Sample baseline todos
        todos = [
          { id: '1', text: 'Define styling guidelines in global.css', completed: true },
          { id: '2', text: 'Create dynamic Todo component', completed: false },
          { id: '3', text: 'Verify responsive build compile', completed: false }
        ];
        saveTodos();
      }
    } catch (e) {
      console.error('Error loading todos:', e);
      todos = [];
    }
  }

  // Save Todos to LocalStorage
  function saveTodos() {
    try {
      localStorage.setItem('taskflow_todos', JSON.stringify(todos));
    } catch (e) {
      console.error('Error saving todos:', e);
    }
  }

  // Render Toasts (ex-toast layout)
  function showToast(message: string, type: 'success' | 'info' | 'error' = 'success') {
    const toast = document.createElement('div');
    toast.className = 'pointer-events-auto flex items-center justify-between bg-canvas border border-hairline rounded-md px-4 py-3 shadow-lvl-4 transform translate-y-4 opacity-0 transition-all duration-300 max-w-sm w-full font-sans text-xs';
    
    // Icon color based on type
    let iconColor = 'text-success';
    let iconSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mr-2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
    
    if (type === 'error') {
      iconColor = 'text-error';
      iconSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mr-2.5"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>`;
    } else if (type === 'info') {
      iconColor = 'text-link';
      iconSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mr-2.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>`;
    }

    toast.innerHTML = `
      <div class="flex items-center text-body">
        <span class="${iconColor}">${iconSvg}</span>
        <span class="font-medium text-ink">${message}</span>
      </div>
      <button class="toast-close ml-4 text-mute hover:text-ink cursor-pointer transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    `;

    toastContainer.appendChild(toast);

    // Trigger animation
    setTimeout(() => {
      toast.classList.remove('translate-y-4', 'opacity-0');
    }, 10);

    // Auto remove
    const timer = setTimeout(() => {
      removeToast(toast);
    }, 4000);

    // Close click handler
    toast.querySelector('.toast-close')?.addEventListener('click', () => {
      clearTimeout(timer);
      removeToast(toast);
    });
  }

  function removeToast(toast: HTMLDivElement) {
    toast.classList.add('translate-y-[-4px]', 'opacity-0');
    setTimeout(() => {
      toast.remove();
    }, 300);
  }

  // Render Todos
  function render() {
    // Filter logic
    const filteredTodos = todos.filter(todo => {
      if (currentFilter === 'active') return !todo.completed;
      if (currentFilter === 'completed') return todo.completed;
      return true;
    });

    // Clear previous
    todoList.innerHTML = '';

    if (filteredTodos.length === 0) {
      emptyState.classList.remove('hidden');
    } else {
      emptyState.classList.add('hidden');
      
      // Build elements
      filteredTodos.forEach(todo => {
        const item = document.createElement('div');
        item.className = `group flex items-center justify-between bg-canvas border border-hairline rounded-md px-4 py-3 shadow-lvl-1 hover:shadow-lvl-2 transition-all duration-200 animate-in fade-in duration-200 ${todo.completed ? 'bg-canvas-soft-2/50 border-hairline/60' : ''}`;
        item.setAttribute('data-id', todo.id);

        item.innerHTML = `
          <div class="flex items-center gap-3 flex-1 min-w-0">
            <!-- Custom checkbox -->
            <button 
              type="button" 
              class="todo-check-btn flex-shrink-0 w-5 h-5 rounded-full border ${todo.completed ? 'bg-primary border-primary text-on-primary' : 'bg-canvas border-hairline-strong hover:border-ink'} flex items-center justify-center transition-all cursor-pointer"
              aria-label="${todo.completed ? 'Mark incomplete' : 'Mark complete'}"
            >
              <svg class="w-3 h-3 ${todo.completed ? 'block' : 'hidden'}" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path>
              </svg>
            </button>

            <!-- Editable Text content -->
            <div class="flex-1 min-w-0 pr-4">
              <span class="todo-text block text-sm font-sans truncate cursor-pointer select-none transition-all duration-200 py-1 ${todo.completed ? 'text-mute line-through' : 'text-ink'}" title="Double click to edit">
                ${escapeHtml(todo.text)}
              </span>
              <input 
                type="text" 
                class="todo-edit-input hidden w-full px-2 py-1 text-sm bg-canvas border border-hairline-strong rounded-[4px] focus:outline-none focus:ring-1 focus:ring-ink"
                value="${escapeHtml(todo.text)}"
              />
            </div>
          </div>

          <!-- Actions -->
          <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 focus-within:opacity-100 transition-opacity duration-150">
            <button 
              type="button" 
              class="todo-edit-btn p-1.5 text-body hover:text-ink hover:bg-canvas-soft rounded transition-all cursor-pointer" 
              aria-label="Edit task"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4Z"></path></svg>
            </button>
            <button 
              type="button" 
              class="todo-del-btn p-1.5 text-body hover:text-error hover:bg-error-soft/30 rounded transition-all cursor-pointer" 
              aria-label="Delete task"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
            </button>
          </div>
        `;

        // Attach events
        // Toggle completed
        item.querySelector('.todo-check-btn')?.addEventListener('click', () => toggleCompleted(todo.id));
        
        // Double click to edit or click the edit icon
        const textSpan = item.querySelector('.todo-text') as HTMLSpanElement;
        const editInput = item.querySelector('.todo-edit-input') as HTMLInputElement;
        const editBtn = item.querySelector('.todo-edit-btn') as HTMLButtonElement;

        const startEdit = () => {
          textSpan.classList.add('hidden');
          editInput.classList.remove('hidden');
          editInput.focus();
          editInput.setSelectionRange(editInput.value.length, editInput.value.length);
        };

        const finishEdit = () => {
          const newText = editInput.value.trim();
          if (newText && newText !== todo.text) {
            editTodoText(todo.id, newText);
          }
          textSpan.classList.remove('hidden');
          editInput.classList.add('hidden');
        };

        textSpan?.addEventListener('dblclick', startEdit);
        editBtn?.addEventListener('click', startEdit);

        editInput?.addEventListener('blur', finishEdit);
        editInput?.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            finishEdit();
          } else if (e.key === 'Escape') {
            editInput.value = todo.text; // reset
            textSpan.classList.remove('hidden');
            editInput.classList.add('hidden');
          }
        });

        // Delete todo
        item.querySelector('.todo-del-btn')?.addEventListener('click', () => deleteTodo(todo.id));

        todoList.appendChild(item);
      });
    }

    // Update remaining items count
    const remainingCount = todos.filter(t => !t.completed).length;
    activeCountEl.textContent = remainingCount.toString();

    // Show/hide clear completed button
    const hasCompleted = todos.some(t => t.completed);
    if (hasCompleted) {
      clearCompletedBtn.classList.remove('invisible');
      clearCompletedBtn.classList.add('visible');
    } else {
      clearCompletedBtn.classList.remove('visible');
      clearCompletedBtn.classList.add('invisible');
    }
  }

  // Utilities
  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.innerText = text;
    return div.innerHTML;
  }

  // Actions
  function addTodo(text: string) {
    const newTodo: Todo = {
      id: Date.now().toString(),
      text: text,
      completed: false
    };
    todos.unshift(newTodo);
    saveTodos();
    render();
    showToast(`Task added: "${text}"`, 'success');
  }

  function toggleCompleted(id: string) {
    const todo = todos.find(t => t.id === id);
    if (todo) {
      todo.completed = !todo.completed;
      saveTodos();
      render();
      showToast(todo.completed ? `Task completed` : `Task active`, 'info');
    }
  }

  function editTodoText(id: string, newText: string) {
    const todo = todos.find(t => t.id === id);
    if (todo) {
      const oldText = todo.text;
      todo.text = newText;
      saveTodos();
      render();
      showToast(`Task updated`, 'info');
    }
  }

  function deleteTodo(id: string) {
    const todo = todos.find(t => t.id === id);
    if (todo) {
      todos = todos.filter(t => t.id !== id);
      saveTodos();
      render();
      showToast(`Task deleted`, 'error');
    }
  }

  // Add event submit
  todoForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const val = todoInput.value.trim();
    if (val) {
      addTodo(val);
      todoInput.value = '';
    }
  });

  // Clear completed handler
  clearCompletedBtn.addEventListener('click', () => {
    const beforeCount = todos.length;
    todos = todos.filter(t => !t.completed);
    const deletedCount = beforeCount - todos.length;
    if (deletedCount > 0) {
      saveTodos();
      render();
      showToast(`Cleared ${deletedCount} completed tasks`, 'info');
    }
  });

  // Filter click handlers
  filterBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const filter = target.getAttribute('data-filter') as 'all' | 'active' | 'completed';
      
      // Update active state class styles
      filterBtns.forEach(b => {
        b.classList.remove('bg-canvas', 'text-ink', 'shadow-lvl-1');
        b.classList.add('hover:text-ink');
      });
      target.classList.add('bg-canvas', 'text-ink', 'shadow-lvl-1');
      target.classList.remove('hover:text-ink');

      currentFilter = filter;
      render();
    });
  });

  // Initialize
  loadTodos();
  render();
</script>
